PORT=3001
# Render: either (A) Root Directory = empty/repo root — build: pip install -r requirements.txt
#   start: cd backend && gunicorn app.main:app --workers 1 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT
#   or (B) Root Directory = backend — build: pip install -r requirements.txt
#   start: gunicorn app.main:app --workers 1 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT
JWT_SECRET=change-this-to-a-long-random-string-for-local-dev
FRONTEND_ORIGIN=http://localhost:5173

# Optional: HR “Summarize resumes” uses OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# Cheapest default; use gpt-4o-mini if your key returns "model not found"
OPENAI_MODEL=gpt-5-nano
